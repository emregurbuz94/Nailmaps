// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id       String   @id
  name     String
  district String
  address  String
  lat      Float
  lng      Float
  rating   Float
  reviews  Int
  about    String
  pattern  String
  colorA   String
  colorB   String
  colorC   String

  services     Service[]
  appointments Appointment[]
}

model Service {
  id       String @id
  salonId  String
  salon    Salon  @relation(fields: [salonId], references: [id])
  name     String
  duration String
  price    Int

  appointments Appointment[]

  @@index([salonId])
}

model Appointment {
  id          String   @id @default(cuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id])
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  salonName   String
  serviceName String
  duration    String
  price       Int
  dateLabel   String
  dayNum      Int
  monthLabel  String
  time        String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@index([salonId])
  @@index([userId])
}

// ---------- Auth.js (NextAuth) modelleri ----------
// Şema, @auth/prisma-adapter'ın beklediği standart yapıyı izler:
// https://authjs.dev/getting-started/adapters/prisma

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  appointments Appointment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
