// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Salon {
  id       String   @id
  name     String
  district String
  address  String
  lat      Float
  lng      Float
  rating   Float
  reviews  Int
  about    String
  pattern  String
  colorA   String
  colorB   String
  colorC   String

  services     Service[]
  appointments Appointment[]
}

model Service {
  id       String @id
  salonId  String
  salon    Salon  @relation(fields: [salonId], references: [id])
  name     String
  duration String
  price    Int

  appointments Appointment[]

  @@index([salonId])
}

model Appointment {
  id          String   @id @default(cuid())
  salonId     String
  salon       Salon    @relation(fields: [salonId], references: [id])
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  salonName   String
  serviceName String
  duration    String
  price       Int
  dateLabel   String
  dayNum      Int
  monthLabel  String
  time        String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@index([salonId])
}
